{
  "compilerOptions": {
    "outDir": "./dist",
    /* rootDir must be set explicitly to ".." (= packages/) because adapter .ts files
       transitively import @persian/* which resolves into ../persian/src/, making the
       true common source ancestor packages/ rather than just database/. Without this,
       TypeScript computes rootDir as ".." automatically and emits TS5011. */
    "rootDir": "..",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "ignoreDeprecations": "6.0",
    "target": "esnext",
    "lib": ["esnext"],
    "types": ["node"],
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "noUncheckedSideEffectImports": true,
    "moduleDetection": "force",
    "skipLibCheck": true,
    /* Path Mapping */
    "baseUrl": ".",
    "paths": {
      /* @/ resolves to database's own src first; falls back to persian/src so that
         persian files pulled in via rootDirs can resolve their own @/ imports without TS2307. */
      "@/*": ["./src/*", "../persian/src/*"],
      /* @persian/* lets adapter repo files (imported transitively by src/index.ts)
         resolve @persian/engine/… and @persian/server/… without TS2307.
         Mirrors the identical mapping in persian/tsconfig.json and the adapter tsconfigs. */
      "@persian/*": ["../persian/src/*"]
    },
    /* rootDirs replaces rootDir so tsc accepts files in ../adapters/ src without TS6059.
       src/index.ts imports adapter repos via relative paths; with rootDir: "./src" tsc
       rejects any file outside ./src. rootDirs declares all source trees as a merged
       virtual root — the same pattern persian/tsconfig.json already uses for the
       inverse direction (persian importing from ../database/adapters/…). */
    "rootDirs": [
      "./src",
      "./adapters/json/src",
      "./adapters/mongodb/src",
      "./adapters/prisma-sqlite/src",
      "./adapters/prisma-sqlite/src/generated/prisma"
    ]
  },
  "include": ["src"]
}
